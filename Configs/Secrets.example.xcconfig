// Copy this file to Configs/Secrets.xcconfig only if you need a local override,
// such as pointing the app at a staging Supabase project.
// Do NOT commit the real Secrets.xcconfig file.
// Never place service_role or any other privileged server key in this file.

SUPABASE_URL = YOUR_SUPABASE_URL
SUPABASE_ANON_KEY = YOUR_SUPABASE_ANON_KEY
GOOGLE_IOS_CLIENT_ID = YOUR_GOOGLE_IOS_CLIENT_ID
GOOGLE_WEB_CLIENT_ID = YOUR_GOOGLE_WEB_CLIENT_ID
GOOGLE_REVERSED_CLIENT_ID_SCHEME = YOUR_GOOGLE_REVERSED_CLIENT_ID_SCHEME
